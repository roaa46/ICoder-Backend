  "components": {
    "schemas": {
      "UserProfileRequest": {
        "required": [
          "current_password"
        ],
        "type": "object",
        "properties": {
          "current_password": {
            "type": "string"
          },
          "nickname": {
            "type": "string"
          },
          "school": {
            "type": "string"
          }
        }
      },
      "MessageResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        }
      },
      "UpdateEmailRequest": {
        "required": [
          "current_password",
          "new_email"
        ],
        "type": "object",
        "properties": {
          "new_email": {
            "type": "string"
          },
          "current_password": {
            "type": "string"
          }
        }
      },
      "RegisterRequest": {
        "required": [
          "email",
          "handle",
          "nickname",
          "password",
          "password_confirmation"
        ],
        "type": "object",
        "properties": {
          "handle": {
            "type": "string"
          },
          "nickname": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "password": {
            "maxLength": 20,
            "minLength": 8,
            "pattern": "^(?=.*[a-z])(?=.*[A-Z])(?=.*\\d)(?=.*[@$!%*?&])[A-Za-z\\d@$!%*?&]+$",
            "type": "string"
          },
          "password_confirmation": {
            "type": "string"
          },
          "verified": {
            "type": "boolean"
          },
          "last_verification_email_sent_at": {
            "type": "string"
          },
          "created_at": {
            "type": "string"
          },
          "accepted_count": {
            "type": "integer",
            "format": "int32"
          },
          "attempted_count": {
            "type": "integer",
            "format": "int32"
          },
          "picture_url": {
            "type": "string"
          },
          "school": {
            "type": "string"
          }
        }
      },
      "ResetPasswordRequest": {
        "required": [
          "confirmation_password",
          "new_password",
          "token"
        ],
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          },
          "new_password": {
            "maxLength": 20,
            "minLength": 8,
            "pattern": "^(?=.*[a-z])(?=.*[A-Z])(?=.*\\d)(?=.*[@$!%*?&])[A-Za-z\\d@$!%*?&]+$",
            "type": "string"
          },
          "confirmation_password": {
            "type": "string"
          }
        }
      },
      "ForgetPasswordRequest": {
        "required": [
          "email"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          }
        }
      },
      "LoginRequest": {
        "required": [
          "handle",
          "password"
        ],
        "type": "object",
        "properties": {
          "handle": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string"
          },
          "refresh_token": {
            "type": "string"
          }
        }
      },
      "ChangePasswordRequest": {
        "required": [
          "current_password",
          "new_password",
          "password_confirmation"
        ],
        "type": "object",
        "properties": {
          "current_password": {
            "type": "string"
          },
          "new_password": {
            "maxLength": 20,
            "minLength": 8,
            "pattern": "^(?=.*[a-z])(?=.*[A-Z])(?=.*\\d)(?=.*[@$!%*?&])[A-Za-z\\d@$!%*?&]+$",
            "type": "string"
          },
          "password_confirmation": {
            "type": "string"
          }
        }
      },
      "UserProfileResponse": {
        "required": [
          "accepted_count",
          "attempted_count",
          "email",
          "handle",
          "nickname",
          "verified"
        ],
        "type": "object",
        "properties": {
          "handle": {
            "type": "string"
          },
          "nickname": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "school": {
            "type": "string"
          },
          "picture_url": {
            "type": "string"
          },
          "verified": {
            "type": "boolean"
          },
          "accepted_count": {
            "type": "integer",
            "format": "int32"
          },
          "attempted_count": {
            "type": "integer",
            "format": "int32"
          }
        }
      }
    }
  }
}